\frametitle{Function Best Practices}
\begin{block}{Local Variables and Returns}
\begin{verbatim}
# Use local variables
calculate() {
    local a=$1
    local b=$2
    local result=$((a + b))
    echo $result
}

# Return exit status
is_valid() {
    if [ -f "$1" ]; then
        return 0  # Success
    else
        return 1  # Failure
    fi
}

if is_valid "file.txt"; then
    echo "File is valid"
fi
\end{verbatim}
\end{block}
