\frametitle{Arrays}
\begin{block}{Working with Arrays}
\begin{verbatim}
# Create array
fruits=("apple" "banana" "cherry")

# Access elements
echo ${fruits[0]}        # First element
echo ${fruits[@]}        # All elements
echo ${#fruits[@]}       # Array length

# Add elements
fruits+=("date")

# Iterate over array
for fruit in "${fruits[@]}"; do
    echo $fruit
done

# Slice array
echo ${fruits[@]:1:2}    # Elements 1-2
\end{verbatim}
\end{block}
