\frametitle{Creating a Script}
\begin{block}{Basic Script Structure}
\begin{verbatim}
#!/bin/bash
# This is a comment

echo "Hello, World!"
echo "Current directory: $(pwd)"
echo "User: $USER"
\end{verbatim}
\end{block}
\begin{exampleblock}<2->{Making it Executable}\label{sec:org4b25ad2}
\begin{verbatim}
chmod +x script.sh
./script.sh
\end{verbatim}
\end{exampleblock}
