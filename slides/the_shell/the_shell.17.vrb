\frametitle{PATH Variable - Example}
\begin{block}{Exploring PATH}
\begin{verbatim}
# Display PATH
cmsc398w:~$ echo $PATH
/usr/local/sbin:/usr/local/bin:/usr/sbin:
/usr/bin:/sbin:/bin:/snap/bin

# Find location of command
cmsc398w:~$ which echo
/usr/bin/echo

# Run directly without PATH
cmsc398w:~$ /bin/echo $PATH
/usr/local/sbin:/usr/local/bin:/usr/sbin:
/usr/bin:/sbin:/bin:/snap/bin
\end{verbatim}
\end{block}
