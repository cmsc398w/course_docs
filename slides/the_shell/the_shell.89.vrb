\frametitle{Advanced Loop Techniques}
\#\#\# Loop Control
:BEAMER\textsubscript{ENV}: block

\begin{verbatim}
# Break out of loop
for i in {1..10}; do
    if [ $i -eq 5 ]; then
        break
    fi
    echo $i
done

# Continue to next iteration
for i in {1..10}; do
    if [ $i -eq 5 ]; then
        continue
    fi
    echo $i
done

# Read file line by line
while IFS= read -r line; do
    echo "Line: $line"
done < file.txt
\end{verbatim}
