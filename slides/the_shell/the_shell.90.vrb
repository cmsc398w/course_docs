\frametitle{Functions}
\begin{block}{Defining Functions}
\begin{verbatim}
#!/bin/bash

# Define function
greet() {
    echo "Hello, $1!"
}

# Call function
greet "Alice"
greet "Bob"

# Function with return value
add() {
    local result=$(($1 + $2))
    echo $result
}

sum=$(add 5 3)
echo "Sum: $sum"
\end{verbatim}
\end{block}
